# Copy this file to `.env` and fill in your values.
# `.env` is git-ignored — never commit real keys.
#   cp .env.example .env

# --- Server ---
PORT=3000

# Where the SQLite database file lives (optional; defaults next to the server).
# DB_PATH=./data.sqlite

# --- LLM provider (PROVIDER-AGNOSTIC) ---
# These three values are the ONLY thing tying the app to a model provider.
# Point them at ANY provider that exposes an OpenAI-compatible
# `/chat/completions` endpoint, or at a local model server. Switching
# providers is a config change here — no code changes anywhere else.
LLM_BASE_URL=https://api.your-provider.example/v1
LLM_API_KEY=replace-me
LLM_MODEL=your-model-name

# Offline demo mode: set to 1 (or leave LLM_API_KEY empty) to run the whole
# app end-to-end with a canned, no-network response — so you can try it before
# wiring up a real provider. Set to 0 once you've added a real key above.
LLM_OFFLINE=1
